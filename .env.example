# LabButler environment configuration.
# Copy to .env and edit. NEVER commit a real .env (it is git-ignored).

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=Europe/Berlin

# --- Database (PostgreSQL — required; SQLite is not supported) ---
# For the bundled Docker Compose "db" service, just set the POSTGRES_* vars below;
# DATABASE_URL is derived from them automatically (single source of truth, so the app
# password can never drift from the DB password). Use a URL-safe POSTGRES_PASSWORD.
POSTGRES_USER=labbutler
POSTGRES_PASSWORD=labbutler
POSTGRES_DB=labbutler
# Only set DATABASE_URL to override the default — e.g. a managed/external database, or
# local dev via scripts/pg.sh (project-local Postgres on port 55432). URL-encode any
# special characters in the password here.
#   DATABASE_URL=postgres://labbutler@localhost:55432/labbutler

# --- Celery / Redis ---
CELERY_BROKER_URL=redis://broker:6379/0
CELERY_RESULT_BACKEND=redis://broker:6379/1
CELERY_TASK_ALWAYS_EAGER=false

# --- Media (attachments: SDS/MSDS, quotes) ---
DJANGO_MEDIA_ROOT=/data/media

# --- Email (SMTP) ---
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=labbutler@example.org
# Days a password-reset / invite set-password link stays valid.
PASSWORD_RESET_TIMEOUT_DAYS=3

# --- Login brute-force protection (django-axes) ---
# Lock a client IP + username after this many failed sign-ins, for this many hours.
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_HOURS=1
# IMPORTANT behind a reverse proxy: set the number of proxies in front so the real
# client IP is used (0 = none; otherwise everyone shares the proxy's IP).
AXES_IPWARE_PROXY_COUNT=1

# --- Notifications ---
# Absolute base URL for links in emails (leave blank to omit links). Required for working
# set-password links in the welcome email sent to newly-added members.
LABBUTLER_BASE_URL=https://labbutler.example.org
# Weekly expiry report: send day (celery beat crontab day_of_week) and local send hour.
# Content (look-ahead window, only-new filter, owned-only) is a per-member setting.
EXPIRY_DIGEST_WEEKDAY=mon
EXPIRY_DIGEST_HOUR=7
# Local hour for the daily procurement digest (pending approvals + request updates).
NOTIFY_DIGEST_HOUR=7

# --- Impersonation ---
# Superuser "view as another user" (for testing roles). Off unless explicitly enabled;
# every action taken while impersonating is audit-logged with the real superuser.
LABBUTLER_IMPERSONATION_ENABLED=false
